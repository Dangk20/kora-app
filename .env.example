# KORA — desarrollo local (NO commitear; ver .env.example)
DATABASE_URL="postgresql://kora:CHANGE_ME@localhost:5433/kora?schema=public"
REDIS_URL="redis://localhost:6380"

AUTH_SECRET="CHANGE_ME_openssl_rand_base64_32"
AUTH_TRUST_HOST=true

# Imágenes de producto (Cloudflare R2).
# Si estas variables están vacías, en desarrollo las imágenes se guardan en
# ./.uploads y se sirven por /media/*. En PRODUCCIÓN son obligatorias: el VPS
# nunca sirve imágenes de producto.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# Base desechable para calcular migraciones (solo desarrollo).
# Créala una vez: docker exec kora-postgres psql -U kora -d kora -c "CREATE DATABASE kora_shadow;"
SHADOW_DATABASE_URL="postgresql://kora:CHANGE_ME@localhost:5433/kora_shadow?schema=public"
